# llama.cpp runtime image for Strix Halo (stock ROCm/Vulkan).
#
# Build from the repository root so this file can copy shared build assets:
#   bin/build.sh rocm
#   bin/build.sh rocm-next
#   bin/build.sh vulkan

ARG FEDORA_VERSION=44
ARG BUILD_TYPE=rocm
ARG ROCM_VERSION=7.2.4
ARG ROCM_REPO_URL=https://repo.radeon.com/rocm/rhel10/7.2.4/main
ARG ROCM_MAJOR_VERSION=7
ARG ROCM_NIGHTLY_BASE_URL=https://therock-nightly-tarball.s3.amazonaws.com
ARG ROCM_NIGHTLY_TARBALL=therock-dist-linux-gfx1151-7.13.0a20260515.tar.gz
ARG GFX_TARGET=gfx1151
ARG CPU_TARGET=generic
ARG ROCWMMA_FATTN=0
ARG LLAMA_REPO=https://github.com/ggml-org/llama.cpp.git
ARG LLAMA_BRANCH=master
ARG LLAMA_REF=

# build stage
FROM registry.fedoraproject.org/fedora:${FEDORA_VERSION} AS builder

ARG BUILD_TYPE
ARG ROCM_VERSION
ARG ROCM_REPO_URL
ARG ROCM_MAJOR_VERSION
ARG ROCM_NIGHTLY_BASE_URL
ARG ROCM_NIGHTLY_TARBALL
ARG GFX_TARGET
ARG CPU_TARGET
ARG ROCWMMA_FATTN
ARG LLAMA_REPO
ARG LLAMA_BRANCH
ARG LLAMA_REF

RUN case "${BUILD_TYPE}" in \
  rocm|rocm-next|vulkan) ;; \
  *) echo "Unsupported BUILD_TYPE: ${BUILD_TYPE}" >&2; exit 1 ;; \
  esac

RUN case "${ROCWMMA_FATTN}" in \
  0|1) ;; \
  *) echo "Unsupported ROCWMMA_FATTN: ${ROCWMMA_FATTN}" >&2; exit 1 ;; \
  esac

# Keep downloaded RPMs in the Buildah cache mount. The cache is not committed
# into the image, so there is no dnf clean step in cached package layers.
RUN echo 'keepcache=True' >> /etc/dnf/dnf.conf

RUN --mount=type=cache,id=dnf-rocm-base,target=/var/cache/libdnf5 \
  echo ">>> Installing builder base packages for ${BUILD_TYPE}" \
  && \
  dnf -y --nodocs --setopt=install_weak_deps=False \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  make gcc cmake lld clang clang-devel compiler-rt libcurl-devel ninja-build libatomic \
  git-core vim sudo rsync patch curl tar xz aria2

# ROCm stable: use AMD's published RHEL 10 repository. This is the stable ROCm
# path and the only path that installs ROCm from RPMs in the runtime stage.
RUN if [ "${BUILD_TYPE}" = "rocm" ]; then \
  printf '%s\n' \
  "[ROCm-${ROCM_VERSION}]" \
  "name=ROCm${ROCM_VERSION}" \
  "baseurl=${ROCM_REPO_URL}" \
  "enabled=1" \
  "priority=50" \
  "gpgcheck=1" \
  "gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key" \
  > /etc/yum.repos.d/rocm.repo; \
  fi

RUN --mount=type=cache,id=dnf-rocm-724,target=/var/cache/libdnf5 \
  if [ "${BUILD_TYPE}" = "rocm" ]; then \
  echo ">>> Installing ROCm ${ROCM_VERSION} builder packages"; \
  rocwmma_packages=""; \
  if [ "${ROCWMMA_FATTN}" = "1" ]; then \
  rocwmma_packages="rocwmma-devel"; \
  fi; \
  dnf -y --nodocs --setopt=install_weak_deps=False \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  rocm-llvm rocm-device-libs hip-runtime-amd hip-devel \
  rocblas rocblas-devel hipblas hipblas-devel rocm-cmake libomp-devel libomp \
  rocminfo radeontop ${rocwmma_packages}; \
  fi

# ROCm nightlies: TheRock publishes a self-contained tarball per GPU target.
# Cache the tarball and copy a trimmed ROCm tree into the final image instead
# of installing ROCm packages there.
WORKDIR /tmp
RUN --mount=type=cache,id=rocm-nightly-tarballs,target=/var/cache/rocm-nightly \
  if [ "${BUILD_TYPE}" = "rocm-next" ]; then \
  set -euo pipefail; \
  if [ -n "${ROCM_NIGHTLY_TARBALL}" ]; then \
  key="${ROCM_NIGHTLY_TARBALL}"; \
  echo ">>> Using pinned ROCm nightly tarball"; \
  else \
  echo ">>> Resolving latest ROCm nightly tarball"; \
  prefix="therock-dist-linux-${GFX_TARGET}-${ROCM_MAJOR_VERSION}"; \
  key="$(curl -fsSL "${ROCM_NIGHTLY_BASE_URL}?list-type=2&prefix=${prefix}" \
    | tr '<' '\n' \
    | grep -o "therock-dist-linux-${GFX_TARGET}-${ROCM_MAJOR_VERSION}\..*\.tar\.gz" \
    | sort -V \
    | tail -n1)"; \
  fi; \
  test -n "${key}"; \
  echo "ROCm nightly tarball: ${key}"; \
  if [ ! -f "/var/cache/rocm-nightly/${key}" ]; then \
  echo ">>> Downloading ROCm nightly tarball"; \
  aria2c -x 16 -s 16 -j 16 --file-allocation=none \
  "${ROCM_NIGHTLY_BASE_URL}/${key}" \
  -d /var/cache/rocm-nightly \
  -o "${key}"; \
  fi; \
  echo ">>> Extracting ROCm nightly tarball"; \
  mkdir -p /opt/rocm; \
  tar xzf "/var/cache/rocm-nightly/${key}" -C /opt/rocm --strip-components=1; \
  mkdir -p /opt/rocm/amdgcn; \
  test -e /opt/rocm/amdgcn/bitcode || \
  ln -s ../lib/llvm/amdgcn/bitcode /opt/rocm/amdgcn/bitcode; \
  fi

# Vulkan RADV: Mesa's RADV driver comes from Fedora packages. No ROCm runtime is
# copied for this target; llama.cpp is built with GGML_VULKAN below.
RUN --mount=type=cache,id=dnf-vulkan-radv,target=/var/cache/libdnf5 \
  if [ "${BUILD_TYPE}" = "vulkan" ]; then \
  echo ">>> Installing Vulkan RADV builder packages"; \
  dnf -y --nodocs --setopt=install_weak_deps=False \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  vulkan-loader-devel vulkaninfo mesa-vulkan-drivers \
  spirv-headers-devel radeontop glslc glslang; \
  fi

# Build-time ROCm/HIP paths are needed for the TheRock nightly tarball target.
# They are intentionally not exported in the final runtime image.
ENV ROCM_PATH=/opt/rocm \
  HIP_PLATFORM=amd \
  HIP_PATH=/opt/rocm \
  HIP_CLANG_PATH=/opt/rocm/llvm/bin \
  HIP_INCLUDE_PATH=/opt/rocm/include \
  HIP_LIB_PATH=/opt/rocm/lib \
  HIP_DEVICE_LIB_PATH=/opt/rocm/amdgcn/bitcode \
  PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH \
  LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64:/opt/rocm/llvm/lib \
  LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64 \
  CPATH=/opt/rocm/include \
  PKG_CONFIG_PATH=/opt/rocm/lib/pkgconfig

# Shared llama.cpp checkout. The source cache is shared by all targets, while
# each target uses its own CMake build directory to avoid stale backend state.
WORKDIR /opt/llama.cpp

RUN --mount=type=cache,id=llama-source,target=/opt/llama.cpp \
  echo ">>> Ensuring llama.cpp source checkout exists" \
  && \
  test -d .git || git clone -b "${LLAMA_BRANCH}" --single-branch --recursive "${LLAMA_REPO}" .

COPY patches/llama-grammar.patch /tmp/llama-grammar.patch

# GCC 16 warns when llama.cpp ORs the different mtmd interpolation enum types.
RUN --mount=type=cache,id=llama-source,target=/opt/llama.cpp \
  echo ">>> Updating llama.cpp source and applying local patch" \
  && \
  git reset --hard \
  && \
  git remote set-url origin "${LLAMA_REPO}" \
  && \
  git fetch origin "${LLAMA_BRANCH}:refs/remotes/origin/${LLAMA_BRANCH}" \
  && git checkout -B "${LLAMA_BRANCH}" "origin/${LLAMA_BRANCH}" \
  && git reset --hard "origin/${LLAMA_BRANCH}" \
  && if [ -n "${LLAMA_REF}" ]; then \
    git checkout --detach "${LLAMA_REF}"; \
  fi \
  && git submodule update --init --recursive \
  && patch -p1 < /tmp/llama-grammar.patch \
  && sed -i \
    's@^#define DEFAULT_INTERPOLATION_MODE (GGML_SCALE_MODE_BILINEAR | GGML_SCALE_FLAG_ANTIALIAS)$@#define DEFAULT_INTERPOLATION_MODE (uint32_t(GGML_SCALE_MODE_BILINEAR) | uint32_t(GGML_SCALE_FLAG_ANTIALIAS))@' \
    tools/mtmd/clip-graph.h \
  && grep -q 'uint32_t(GGML_SCALE_MODE_BILINEAR)' tools/mtmd/clip-graph.h

# Backend-specific llama.cpp configuration. Keep the three target blocks close
# together so it is clear which CMake flags belong to ROCm stable, ROCm next,
# and Vulkan.
# CPU_TARGET controls the CPU code path independently from the GPU backend:
# generic    portable AVX2 build, reproducible across normal x86_64 runners
# strix-halo explicit Strix Halo AVX512/VNNI/BF16 features, reproducible when
#             building on a runner whose compiler supports those switches
# native     host-native detection for local experiments only
RUN --mount=type=cache,id=llama-source,target=/opt/llama.cpp \
  echo ">>> Configuring and building llama.cpp for ${BUILD_TYPE}/${CPU_TARGET}" \
  && \
  case "${CPU_TARGET}" in \
    generic) cpu_flags="-DGGML_NATIVE=OFF" ;; \
    strix-halo) cpu_flags="-DGGML_NATIVE=OFF -DGGML_AVX=ON -DGGML_AVX2=ON -DGGML_F16C=ON -DGGML_FMA=ON -DGGML_BMI2=ON -DGGML_AVX_VNNI=ON -DGGML_AVX512=ON -DGGML_AVX512_VBMI=ON -DGGML_AVX512_VNNI=ON -DGGML_AVX512_BF16=ON" ;; \
    native) cpu_flags="-DGGML_NATIVE=ON" ;; \
    *) echo "Unsupported CPU_TARGET: ${CPU_TARGET}" >&2; exit 1 ;; \
  esac \
  && rocwmma_flags="" \
  && if [ "${ROCWMMA_FATTN}" = "1" ] && [ "${BUILD_TYPE}" != "vulkan" ]; then \
  rocwmma_flags="-DGGML_HIP_ROCWMMA_FATTN=ON"; \
  fi \
  && build_dir="build-${BUILD_TYPE}-${CPU_TARGET}" \
  && rm -rf "${build_dir}" \
  && if [ "${BUILD_TYPE}" = "rocm" ]; then \
  cmake -S . -B "${build_dir}" -G Ninja \
    -DGGML_HIP=ON \
    ${cpu_flags} \
    ${rocwmma_flags} \
    -DCMAKE_HIP_FLAGS="--rocm-path=/opt/rocm -mllvm --amdgpu-unroll-threshold-local=600" \
    -DAMDGPU_TARGETS="${GFX_TARGET}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_RPC=OFF \
    -DGGML_CCACHE=OFF \
    -DLLAMA_BUILD_TESTS=OFF \
    -DGGML_CUDA_ENABLE_UNIFIED_MEMORY=ON \
    -DROCM_PATH=/opt/rocm \
    -DHIP_PATH=/opt/rocm \
    -DLLAMA_HIP_UMA=ON \
    -DHIP_PLATFORM=amd; \
  elif [ "${BUILD_TYPE}" = "rocm-next" ]; then \
  cmake -S . -B "${build_dir}" -G Ninja \
    -DGGML_HIP=ON \
    ${cpu_flags} \
    ${rocwmma_flags} \
    -DCMAKE_HIP_FLAGS="--rocm-path=/opt/rocm -mllvm --amdgpu-unroll-threshold-local=600" \
    -DAMDGPU_TARGETS="${GFX_TARGET}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_RPC=OFF \
    -DGGML_CCACHE=OFF \
    -DLLAMA_BUILD_TESTS=OFF \
    -DGGML_CUDA_ENABLE_UNIFIED_MEMORY=ON \
    -DROCM_PATH=/opt/rocm \
    -DHIP_PATH=/opt/rocm \
    -DLLAMA_HIP_UMA=ON \
    -DHIP_PLATFORM=amd; \
  elif [ "${BUILD_TYPE}" = "vulkan" ]; then \
  cmake -S . -B "${build_dir}" -G Ninja \
    -DGGML_VULKAN=ON \
    ${cpu_flags} \
    -DCMAKE_CXX_FLAGS="-Wno-nonnull" \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_RPC=OFF \
    -DGGML_CCACHE=OFF \
    -DLLAMA_BUILD_TESTS=OFF; \
  fi \
  && cmake --build "${build_dir}" --config Release \
    --target llama-server llama-cli llama-bench llama-gguf-split llama-quantize

RUN --mount=type=cache,id=llama-source,target=/opt/llama.cpp \
  echo ">>> Installing llama.cpp runtime artifacts" \
  && \
  build_dir="build-${BUILD_TYPE}-${CPU_TARGET}" \
  && mkdir -p /usr/local/bin /usr/local/lib64 \
  && install -m 0755 \
    "/opt/llama.cpp/${build_dir}/bin/llama-server" \
    "/opt/llama.cpp/${build_dir}/bin/llama-cli" \
    "/opt/llama.cpp/${build_dir}/bin/llama-bench" \
    "/opt/llama.cpp/${build_dir}/bin/llama-gguf-split" \
    "/opt/llama.cpp/${build_dir}/bin/llama-quantize" \
    /usr/local/bin/ \
  && find "/opt/llama.cpp/${build_dir}" -type f -name 'lib*.so*' -exec cp {} /usr/local/lib64/ \; \
  && ldconfig

# Runtime ROCm payload: official ROCm installs packages in the final stage, so
# only the nightly tarball target needs a copied /opt/rocm runtime tree.
RUN if [ "${BUILD_TYPE}" = "rocm-next" ]; then \
  echo ">>> Trimming ROCm nightly runtime payload"; \
  find /opt/rocm -type f -name '*.a' -delete; \
  rm -rf \
  /opt/rocm/include \
  /opt/rocm/llvm/include \
  /opt/rocm/llvm/share; \
  mkdir -p /opt/rocm-runtime; \
  cp -a /opt/rocm/. /opt/rocm-runtime/; \
  else \
  mkdir -p /opt/rocm-runtime; \
  fi

COPY scripts/gguf-vram-estimator.py /usr/local/bin/gguf-vram-estimator.py
RUN chmod +x /usr/local/bin/gguf-vram-estimator.py

# runtime stage
FROM registry.fedoraproject.org/fedora-minimal:${FEDORA_VERSION} AS runtime

ARG BUILD_TYPE
ARG ROCM_VERSION
ARG ROCM_REPO_URL

RUN case "${BUILD_TYPE}" in \
  rocm|rocm-next|vulkan) ;; \
  *) echo "Unsupported BUILD_TYPE: ${BUILD_TYPE}" >&2; exit 1 ;; \
  esac

# ROCm stable runtime packages come from AMD's repository. Nightlies bring their
# own /opt/rocm tree from the builder; Vulkan uses only Fedora Mesa packages.
RUN if [ "${BUILD_TYPE}" = "rocm" ]; then \
  printf '%s\n' \
  "[ROCm-${ROCM_VERSION}]" \
  "name=ROCm${ROCM_VERSION}" \
  "baseurl=${ROCM_REPO_URL}" \
  "enabled=1" \
  "priority=50" \
  "gpgcheck=1" \
  "gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key" \
  > /etc/yum.repos.d/rocm.repo; \
  fi

RUN echo 'keepcache=True' >> /etc/dnf/dnf.conf

RUN --mount=type=cache,id=dnf-rocm-runtime,target=/var/cache/libdnf5 \
  echo ">>> Installing runtime base packages for ${BUILD_TYPE}" \
  && \
  microdnf -y --nodocs --setopt=install_weak_deps=0 \
  install \
  bash ca-certificates libatomic libstdc++ libgcc libgomp sudo \
  radeontop procps-ng python3

# ROCm stable runtime: install only the runtime libraries needed by llama.cpp.
RUN --mount=type=cache,id=dnf-rocm-724,target=/var/cache/libdnf5 \
  if [ "${BUILD_TYPE}" = "rocm" ]; then \
  echo ">>> Installing ROCm ${ROCM_VERSION} runtime packages"; \
  microdnf -y --nodocs --setopt=install_weak_deps=0 \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  hip-runtime-amd rocblas hipblas rocminfo; \
  fi

# Vulkan RADV runtime: Mesa driver and Vulkan loader from Fedora. Only /dev/dri
# is required at run time for this target.
RUN --mount=type=cache,id=dnf-vulkan-radv,target=/var/cache/libdnf5 \
  if [ "${BUILD_TYPE}" = "vulkan" ]; then \
  echo ">>> Installing Vulkan RADV runtime packages"; \
  microdnf -y --nodocs --setopt=install_weak_deps=0 \
  --exclude='*sdk*' --exclude='*samples*' --exclude='*-doc*' --exclude='*-docs*' \
  install \
  vulkan-loader vulkaninfo mesa-vulkan-drivers; \
  fi

COPY --from=builder /opt/rocm-runtime/ /opt/rocm/
COPY --from=builder /usr/local/ /usr/local/

# Keep ROCm discoverable through ldconfig, not process-wide HIP/ROCm
# environment variables. The stable image does not export
# those variables, and setting them globally can crash stable ROCm during model
# load on Strix Halo.
RUN echo "/usr/local/lib"  > /etc/ld.so.conf.d/local.conf \
  && echo "/usr/local/lib64" >> /etc/ld.so.conf.d/local.conf \
  && echo "/opt/rocm/lib" >> /etc/ld.so.conf.d/rocm.conf \
  && echo "/opt/rocm/lib64" >> /etc/ld.so.conf.d/rocm.conf \
  && echo "/opt/rocm/llvm/lib" >> /etc/ld.so.conf.d/rocm.conf \
  && echo "/opt/rocm/lib/rocm_sysdeps/lib" >> /etc/ld.so.conf.d/rocm.conf \
  && ldconfig

ENV PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH

CMD ["/bin/bash"]
